---
import GlassCard from './GlassCard.astro';
import { results } from '~/data/results';
---

<section class="reveal scroll-mt-28 py-10 md:py-14">
  <GlassCard class="!p-8 md:!p-12">
    <ul class="grid gap-10 md:grid-cols-3 md:gap-6">
      {results.map((result) => (
        <li class="flex flex-col items-center text-center">
          <p class="bg-gradient-to-br from-[color:var(--text)] to-[color:var(--muted)] bg-clip-text text-5xl font-semibold tracking-tightest text-transparent md:text-6xl lg:text-7xl">
            {result.stat}
          </p>
          <p class="mt-3 max-w-[18ch] text-sm text-[color:var(--muted)] md:text-base">
            {result.label}
          </p>
        </li>
      ))}
    </ul>
  </GlassCard>
</section>
