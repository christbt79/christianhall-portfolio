---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
  class?: string;
}
const { id, eyebrow, title, description, class: className = '' } = Astro.props;
---

<section id={id} class={`reveal scroll-mt-28 py-14 md:py-20 ${className}`}>
  <header class="mb-8 md:mb-12">
    {eyebrow && (
      <p class="mb-2 text-xs font-medium uppercase tracking-[0.2em] text-accent">
        {eyebrow}
      </p>
    )}
    <h2 class="text-3xl font-semibold tracking-tightest md:text-4xl">{title}</h2>
    {description && (
      <p class="mt-3 max-w-2xl text-base text-[color:var(--muted)] md:text-lg">
        {description}
      </p>
    )}
  </header>
  <slot />
</section>
