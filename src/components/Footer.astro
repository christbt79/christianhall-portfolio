---
import { contact, profile } from '~/data/profile';
const year = new Date().getFullYear();
---

<footer class="mx-auto w-full max-w-5xl px-6 pb-14 md:px-10">
  <div class="glass flex flex-col items-start justify-between gap-4 rounded-2xl px-6 py-5 text-sm text-[color:var(--muted)] md:flex-row md:items-center">
    <p>© {year} {profile.name}</p>
    <ul class="flex flex-wrap items-center gap-5">
      <li><a class="hover:text-[color:var(--text)]" href={`mailto:${contact.email}`}>Email</a></li>
      <li><a class="hover:text-[color:var(--text)]" href={contact.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
    </ul>
  </div>
</footer>
