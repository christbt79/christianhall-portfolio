---
import { profile, contact } from '~/data/profile';
import { inlineMd } from '~/lib/inline-md';
import { ArrowUpRight, Mail } from 'lucide-react';
---

<section class="reveal relative pt-6 pb-10 md:pt-12 md:pb-16">
  <div class="grid items-start gap-10 md:grid-cols-[minmax(0,1fr)_auto] md:gap-12">
    <div>
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-black/10 bg-black/[0.03] px-3 py-1 text-xs text-[color:var(--muted)] backdrop-blur dark:border-white/10 dark:bg-white/5">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-70"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        </span>
        Open to new roles
      </p>
      <h1 class="text-5xl font-semibold tracking-tightest md:text-7xl">
        {profile.name}
      </h1>
      <p
        class="mt-4 max-w-2xl text-xl text-[color:var(--muted)] md:text-2xl"
        set:html={inlineMd(`${profile.tagline}. ${profile.summary}`)}
      ></p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={`mailto:${contact.email}`}
          class="group inline-flex items-center gap-2 rounded-full bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-[0_8px_24px_-8px_rgba(79,140,255,0.6)] transition-all duration-300 hover:scale-[1.02] hover:bg-accent-hover"
        >
          <Mail size={16} />
          Get in touch
        </a>
        <a
          href={contact.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="glass group inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all duration-300 hover:scale-[1.02] hover:border-white/20"
        >
          LinkedIn
          <ArrowUpRight
            size={16}
            className="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
          />
        </a>
      </div>
    </div>

    <div class="order-first md:order-none md:mt-24 md:justify-self-end lg:mt-28">
      <div class="relative mx-auto aspect-square w-52 sm:w-60 md:w-72 lg:w-80">
        <!-- Soft accent glow behind the photo -->
        <div
          class="absolute -inset-4 -z-10 rounded-[2rem] opacity-60 blur-2xl"
          style="background: radial-gradient(circle at 30% 30%, rgba(var(--orb-1), 0.55), transparent 60%), radial-gradient(circle at 70% 80%, rgba(var(--orb-2), 0.5), transparent 65%);"
          aria-hidden="true"
        ></div>
        <img
          src="/profile.jpg"
          alt={`Portrait of ${profile.name}`}
          width="512"
          height="512"
          loading="eager"
          decoding="async"
          class="h-full w-full rounded-3xl object-cover shadow-[0_20px_60px_-20px_rgba(79,140,255,0.45)] ring-1 ring-black/10 dark:ring-white/10"
        />
      </div>
    </div>
  </div>
</section>
