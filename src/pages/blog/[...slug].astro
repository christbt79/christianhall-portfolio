---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import GlassCard from '~/components/GlassCard.astro';
import { ArrowLeft } from 'lucide-react';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${post.data.title} — Writing`} description={post.data.description}>
  <a href="/blog" class="reveal mb-8 inline-flex items-center gap-1.5 text-sm text-[color:var(--muted)] transition-colors hover:text-[color:var(--text)]">
    <ArrowLeft size={14} />
    All posts
  </a>
  <article class="reveal">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-[0.2em] text-accent">
        {dateFmt.format(post.data.pubDate)}
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tightest md:text-5xl">
        {post.data.title}
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-[color:var(--muted)]">
        {post.data.description}
      </p>
    </header>
    <GlassCard class="prose prose-lg dark:prose-invert max-w-none prose-headings:tracking-tight prose-p:leading-relaxed prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-code:rounded prose-code:bg-white/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none">
      <Content />
    </GlassCard>
  </article>
</BaseLayout>
